// KC Jewellers — Prisma documents selected tables; full `users` shape lives in PostgreSQL (server.js migrations).
// Runtime uses `pg` in server.js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Values stored in `users.customer_tier` — ADMIN, B2C_CUSTOMER, B2B_WHOLESALE
enum CustomerTier {
  ADMIN
  B2C_CUSTOMER
  B2B_WHOLESALE
}

model SharedCatalog {
  id               String   @id @db.Uuid
  productIds       String[] @map("product_ids")
  markupPercentage Float    @map("markup_percentage")
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("shared_catalogs")
}

model B2bClientLedgerEntry {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  txnCategory    String   @map("txn_category") @db.VarChar(32)
  amountRupees   Decimal  @default(0) @map("amount_rupees") @db.Decimal(16, 2)
  fineMetalGrams Decimal  @default(0) @map("fine_metal_grams") @db.Decimal(16, 6)
  metalType      String?  @map("metal_type") @db.VarChar(32)
  description    String?
  reference      String?  @db.VarChar(128)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)], map: "idx_b2b_ledger_user_created")
  @@map("b2b_client_ledger_entries")
}

model WebProduct {
  id           Int      @id @default(autoincrement())
  subcategoryId Int     @map("subcategory_id")
  sku          String   @unique @db.VarChar(255)
  barcode      String?  @db.VarChar(255)
  name         String   @db.VarChar(255)
  grossWeight  Decimal? @map("gross_weight") @db.Decimal(10, 3)
  netWeight    Decimal? @map("net_weight") @db.Decimal(10, 3)
  purity       String?  @db.VarChar(50)
  imageUrl     String?  @map("image_url")
  isActive     Boolean? @default(true) @map("is_active")
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamp(6)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  mcRate       Decimal? @map("mc_rate") @db.Decimal(12, 2)
  metalType    String?  @map("metal_type") @db.VarChar(50)
  fixedPrice   Decimal? @map("fixed_price") @db.Decimal(12, 2)
  stoneCharges Decimal? @map("stone_charges") @db.Decimal(12, 2)
  designGroup  String?  @map("design_group") @db.VarChar(255)

  @@index([designGroup], map: "idx_web_products_design_group")
  @@map("web_products")
}
