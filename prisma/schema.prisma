// Runtime DB is PostgreSQL (see config/database.js / migrations). This schema documents
// models used by the KC Jewellers app and enables Prisma tooling where configured.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Storefront / ERP user accounts (shared `users` table).
/// Roles: super_admin, admin, employee (ERP) | B2C_CUSTOMER, B2B_WHOLESALE (commerce)
model User {
  id                     Int      @id @default(autoincrement())
  email                  String?  @db.VarChar(255)
  google_id              String?  @db.VarChar(255)
  name                   String?  @db.VarChar(255)
  role                   String   @default("B2C_CUSTOMER") @db.VarChar(64)
  account_status         String?  @db.VarChar(50)
  mobile_number          String?  @db.VarChar(20)
  mc_discount_percent    Decimal? @db.Decimal(6, 3)
  metal_markup_percent   Decimal? @db.Decimal(6, 3)
  ledger_rupee_balance     Decimal? @db.Decimal(14, 2)
  ledger_fine_metal_grams  Decimal? @db.Decimal(14, 6)
  created_at             DateTime? @default(now())
  updated_at             DateTime? @updatedAt

  ledgerEntries UserLedgerEntry[]

  @@map("users")
}

model UserLedgerEntry {
  id                     Int      @id @default(autoincrement())
  user_id                Int
  entry_type             String   @db.VarChar(32)
  rupee_delta            Decimal  @default(0) @db.Decimal(14, 2)
  fine_metal_delta_grams Decimal  @default(0) @db.Decimal(14, 6)
  metal_type             String?  @db.VarChar(32)
  description            String?
  reference              String?  @db.VarChar(128)
  created_at             DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_ledger_entries")
}

model B2bWhitelist {
  id                         Int      @id @default(autoincrement())
  email_norm                 String?  @db.VarChar(255)
  mobile_last10              String?  @db.VarChar(10)
  default_mc_discount_percent  Decimal? @db.Decimal(6, 3)
  default_metal_markup_percent Decimal? @db.Decimal(6, 3)
  notes                      String?
  created_at                 DateTime @default(now()) @db.Timestamptz(6)

  @@map("b2b_whitelist")
}

model SharedCatalog {
  id               String   @id @db.Uuid
  productIds       String[] @map("product_ids")
  markupPercentage Float    @map("markup_percentage")
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("shared_catalogs")
}
