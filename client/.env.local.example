# Copy to .env.local for local development (API on port 4000)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production (example — use your real API and site URLs)
# NEXT_PUBLIC_API_URL=https://api.kcjewellers.co.in
# NEXT_PUBLIC_SITE_URL=https://kcjewellers.co.in

# WhatsApp: digits only, country code included, no + (e.g. 9198XXXXXXXX). Enables the floating “Chat on WhatsApp” button.
# NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=9198XXXXXXXX
# GOOGLE_CALLBACK_URL=https://kcjewellers.co.in/auth/google/callback
# CLIENT_URL=https://kcjewellers.co.in
#
# API server only — B2B NEFT bank details (shown on proforma / checkout success; never hardcode in client source)
# B2B_BANK_ACCOUNT_NAME=
# B2B_BANK_NAME=
# B2B_BANK_ACCOUNT_NUMBER=
# B2B_BANK_IFSC=
# B2B_BANK_UPI_ID=
# B2B_BANK_NOTES=
