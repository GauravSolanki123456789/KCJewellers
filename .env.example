# Backend (copy to .env on the server — do not commit real secrets)
NODE_ENV=production
PORT=4000

# Public URL of this API (no trailing slash) — used for absolute links to /uploads, certificates, ERP sync images
API_PUBLIC_URL=https://api.kcjewellers.co.in

# Optional fallback if API_PUBLIC_URL is not set (hostname only, no scheme)
# DOMAIN=api.kcjewellers.co.in

# Primary web app URL (no trailing slash)
CLIENT_URL=https://kcjewellers.co.in

# Extra browser origins allowed by CORS / Socket.IO (comma-separated), e.g. www
CORS_ORIGINS=https://www.kcjewellers.co.in

# Session cookie for api.* + apex/www: leading dot on registrable domain
COOKIE_DOMAIN=.kcjewellers.co.in

DATABASE_URL=postgresql://user:pass@localhost:5432/kc_jewellers
SESSION_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.kcjewellers.co.in/auth/google/callback

# Optional: restrict admin API to these origin prefixes (comma-separated)
# ADMIN_ALLOWED_ORIGINS=https://kcjewellers.co.in,https://www.kcjewellers.co.in
